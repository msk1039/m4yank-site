---
import { Icon } from "astro-icon/components";
import ImageViewer from "./ImageViewer.astro";
import { getImageDimensions } from "../data/image-dimensions";

interface Slide {
  src: string;
  alt: string;
  caption?: string;
  width?: number;
  height?: number;
}

interface Props {
  slides: Slide[];
  slideHeight?: string;
  class?: string;
  autoplay?: boolean;
  autoplayInterval?: number;
  continuous?: boolean;
  single?: boolean;
  controlsOutside?: boolean;
  speed?: number;
}

const {
  slides,
  slideHeight = "h-[440px] sm:h-[540px]",
  class: className,
  autoplay = false,
  autoplayInterval = 4000,
  continuous = false,
  single = false,
  controlsOutside = false,
  speed = 60,
} = Astro.props;

const slidesWithDims = slides.map((slide) => {
  const dims = getImageDimensions(slide.src);
  return {
    ...slide,
    width: slide.width ?? dims?.width,
    height: slide.height ?? dims?.height,
  };
});

const idPrefix = "carousel";
const loopSlides = continuous
  ? [...slidesWithDims, ...slidesWithDims].map((slide, i) => ({
      ...slide,
      id: `${idPrefix}-${i}`,
    }))
  : slidesWithDims.map((slide, i) => ({
      ...slide,
      id: `${idPrefix}-${i}`,
    }));

const loopDuration = continuous
  ? Math.max((slidesWithDims.length * 400) / speed, 10)
  : 0;
---

{
  loopSlides.length > 0 && (
    <div
      class:list={["max-w-full min-w-0", continuous && "group cursor-pointer"]}
      data-carousel
      data-continuous={continuous ? "true" : undefined}
      data-autoplay={autoplay ? "true" : undefined}
      data-autoplay-interval={autoplay ? autoplayInterval : undefined}
    >
      <div class:list={["relative overflow-hidden", className]}>
        <div
          data-carousel-track
          class:list={[
            "flex gap-4",
            continuous
              ? "animate-marquee w-max group-hover:[animation-play-state:paused]"
              : "snap-x snap-mandatory overflow-x-auto scroll-smooth",
          ]}
          style={
            continuous ? `animation-duration: ${loopDuration}s;` : undefined
          }
        >
          {loopSlides.map((slide, i) => (
            <div
              class:list={[
                "shrink-0",
                slideHeight,
                single && "w-full",
                !continuous && "snap-start",
              ]}
              data-carousel-slide
            >
              <ImageViewer
                id={slide.id}
                src={slide.src}
                alt={slide.alt}
                title={slide.alt}
                caption={slide.caption}
                class:list={[single ? "h-full w-full" : "h-full"]}
                triggerClass="h-full"
              >
                <img
                  src={slide.src}
                  alt={slide.alt}
                  width={slide.width}
                  height={slide.height}
                  loading={i === 0 ? "eager" : "lazy"}
                  decoding="async"
                  class:list={[
                    "rounded-2xl ring-1 ring-black/5 transition-transform duration-500 group-hover/slide:scale-[1.02]",
                    single ? "h-full w-full object-cover" : "h-full w-auto",
                  ]}
                />
              </ImageViewer>
            </div>
          ))}
        </div>

        {!continuous && !controlsOutside && slidesWithDims.length > 1 && (
          <>
            <button
              type="button"
              data-carousel-prev
              aria-label="Previous slide"
              class="bg-background/80 ring-border/60 hover:bg-background absolute top-1/2 left-2 grid size-11 -translate-y-1/2 place-items-center rounded-full backdrop-blur-sm transition-opacity disabled:pointer-events-none disabled:opacity-0 sm:size-9"
            >
              <Icon name="ri:arrow-left-s-line" class="size-6 shrink-0" />
            </button>

            <button
              type="button"
              data-carousel-next
              aria-label="Next slide"
              class="bg-background/80 ring-border/60 hover:bg-background absolute top-1/2 right-2 grid size-11 -translate-y-1/2 place-items-center rounded-full backdrop-blur-sm transition-opacity disabled:pointer-events-none disabled:opacity-0 sm:size-9"
            >
              <Icon name="ri:arrow-right-s-line" class="size-6 shrink-0" />
            </button>
          </>
        )}
      </div>

      {!continuous && controlsOutside && slidesWithDims.length > 1 && (
        <div class="mt-3 flex items-center justify-center gap-3">
          <button
            type="button"
            data-carousel-prev
            aria-label="Previous slide"
            class="bg-muted ring-border/60 hover:bg-background hover:ring-border inline-flex h-10 items-center gap-1.5 rounded-full px-4 font-mono text-xs tracking-wider uppercase ring-1 transition-colors disabled:pointer-events-none disabled:opacity-40"
          >
            <Icon name="ri:arrow-left-s-line" class="size-5 shrink-0" />
            Prev
          </button>

          <button
            type="button"
            data-carousel-next
            aria-label="Next slide"
            class="bg-muted ring-border/60 hover:bg-background hover:ring-border inline-flex h-10 items-center gap-1.5 rounded-full px-4 font-mono text-xs tracking-wider uppercase ring-1 transition-colors disabled:pointer-events-none disabled:opacity-40"
          >
            Next
            <Icon name="ri:arrow-right-s-line" class="size-5 shrink-0" />
          </button>
        </div>
      )}
    </div>
  )
}

<style>
  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .animate-marquee {
    animation-name: marquee;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }
</style>

<script is:inline>
  document.querySelectorAll("[data-carousel]").forEach((carousel) => {
    const track = carousel.querySelector("[data-carousel-track]");
    const slides = carousel.querySelectorAll("[data-carousel-slide]");
    const prev = carousel.querySelector("[data-carousel-prev]");
    const next = carousel.querySelector("[data-carousel-next]");
    if (!track || slides.length === 0) return;

    const isContinuous = carousel.dataset.continuous === "true";
    if (isContinuous) return;

    const gap = 16;
    const step = () => slides[0].getBoundingClientRect().width + gap;

    const update = () => {
      const max = track.scrollWidth - track.clientWidth;
      if (prev) prev.disabled = track.scrollLeft <= 2;
      if (next) next.disabled = track.scrollLeft >= max - 2;
    };

    const isAutoplay = carousel.dataset.autoplay === "true";
    const interval = parseInt(carousel.dataset.autoplayInterval || "4000", 10);
    let timer;

    const advance = () => {
      const max = track.scrollWidth - track.clientWidth;
      if (track.scrollLeft >= max - 2) {
        track.scrollTo({ left: 0, behavior: "smooth" });
      } else {
        track.scrollBy({ left: step(), behavior: "smooth" });
      }
    };

    const start = () => {
      if (!isAutoplay) return;
      stop();
      timer = window.setInterval(advance, interval);
    };

    const stop = () => {
      if (timer) window.clearInterval(timer);
    };

    prev?.addEventListener("click", () => {
      track.scrollBy({ left: -step(), behavior: "smooth" });
      start();
    });
    next?.addEventListener("click", () => {
      track.scrollBy({ left: step(), behavior: "smooth" });
      start();
    });
    track.addEventListener("scroll", update, { passive: true });

    if (isAutoplay) {
      carousel.addEventListener("mouseenter", stop);
      carousel.addEventListener("mouseleave", start);
      start();
    }

    update();
  });
</script>
