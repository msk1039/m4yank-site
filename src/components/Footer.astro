---
import { execSync } from "node:child_process";
import SocialLinks from "./SocialLinks.astro";

const repoUrl = "https://github.com/msk1039";

let commitHash = process.env.VERCEL_GIT_COMMIT_SHA ?? "";
if (!commitHash) {
  try {
    commitHash = execSync("git rev-parse HEAD").toString().trim();
  } catch {
    commitHash = "";
  }
}
const shortHash = commitHash.slice(0, 7);
---

<footer class="py-6">
  <div class="section-inner flex items-center justify-between">
    <SocialLinks eventName="footer_social_clicked" />
    {
      shortHash ? (
        <a
          href={`${repoUrl}/commit/${commitHash}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Latest commit ${shortHash}`}
          class="text-muted-foreground hover:text-foreground font-mono text-xs no-underline"
        >
          {shortHash}
        </a>
      ) : (
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground hover:text-foreground font-mono text-xs no-underline"
        >
          source
        </a>
      )
    }
  </div>
</footer>
