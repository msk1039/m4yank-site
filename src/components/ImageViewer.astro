---
import { Icon } from "astro-icon/components";

interface Props {
  id: string;
  src: string;
  alt: string;
  title?: string;
  caption?: string;
  triggerClass?: string;
  class?: string;
}

const {
  id,
  src,
  alt,
  title = alt,
  caption,
  triggerClass = "",
  class: className = "",
} = Astro.props;
---

<button
  type="button"
  data-image-open={id}
  aria-label={`View ${alt}`}
  class:list={["group relative block cursor-pointer", triggerClass, className]}
>
  <slot>
    <img
      src={src}
      alt={alt}
      loading="lazy"
      decoding="async"
      class="h-auto w-full object-contain transition-transform duration-300 group-hover:scale-[1.02]"
    />
  </slot>
</button>

<dialog
  data-image-dialog={id}
  class="@container m-0 h-dvh max-h-none w-screen max-w-none bg-transparent p-0 backdrop:bg-black/50 backdrop:backdrop-blur-sm"
>
  <div
    class="bg-background text-foreground mx-auto flex h-full w-full flex-col @md:my-[2.5dvh] @md:h-[95dvh] @md:w-[min(90vw,900px)] @md:rounded-2xl"
  >
    <div
      class="border-border/60 flex items-center justify-between border-b px-3 py-1.5"
    >
      <p class="text-xs font-medium">{title}</p>
      <div class="flex items-center gap-0.5">
        <a
          href={src}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open image in new tab"
          class="text-muted-foreground hover:text-foreground hover:bg-foreground/5 inline-flex size-7 items-center justify-center rounded-lg no-underline"
        >
          <Icon name="ri:external-link-line" class="size-4" />
        </a>
        <button
          type="button"
          data-image-close
          aria-label="Close"
          class="text-muted-foreground hover:text-foreground hover:bg-foreground/5 inline-flex size-7 cursor-pointer items-center justify-center rounded-lg"
        >
          <Icon name="ri:close-line" class="size-4" />
        </button>
      </div>
    </div>
    <div
      class="relative flex min-h-0 flex-1 items-center justify-center overflow-hidden p-4"
    >
      <img
        data-image-frame={id}
        src={src}
        alt={alt}
        class="max-h-full max-w-full object-contain"
      />
      {
        caption && (
          <p class="text-muted-foreground absolute right-0 bottom-4 left-0 px-4 text-center text-sm">
            {caption}
          </p>
        )
      }
    </div>
  </div>
</dialog>

<script is:inline define:vars={{ id, src }}>
  const dialog = document.querySelector(`[data-image-dialog="${id}"]`);
  const frame = dialog?.querySelector(`[data-image-frame="${id}"]`);

  document
    .querySelector(`[data-image-open="${id}"]`)
    ?.addEventListener("click", () => {
      if (frame && !frame.src) frame.src = src;
      dialog?.showModal();
      window.posthog?.capture("image_viewer_opened", {
        viewer_id: id,
        image_src: src,
      });
    });

  dialog
    ?.querySelector("[data-image-close]")
    ?.addEventListener("click", () => dialog.close());

  dialog?.addEventListener("click", (event) => {
    if (event.target === dialog) dialog.close();
  });
</script>
