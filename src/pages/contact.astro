---
import Layout from "../layouts/Layout.astro";
import Annotate from "../components/Annotate.astro";
import EmailLink from "../components/EmailLink.astro";
import { contactLinks } from "../data/portfolio";
import { absoluteUrl, buildPersonSchema, siteConfig } from "../lib/seo";

const pageUrl = absoluteUrl("/contact", Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: `Contact · ${siteConfig.name}`,
  description: "Get in touch: email, GitHub, LinkedIn, or X.",
  url: pageUrl,
  mainEntity: buildPersonSchema(Astro.site),
};
---

<Layout
  title="Contact"
  description="Get in touch: email, GitHub, LinkedIn, or X."
  jsonLd={jsonLd}
>
  <main class="isolate">
    <section class="section-shell">
      <div class="section-inner grid gap-12">
        <!-- <div class="grid gap-4">
          <p class="text-muted-foreground text-sm">Contact</p>
          <h1
            class="max-w-[28ch] font-serif text-3xl font-normal tracking-tight text-balance italic md:text-5xl"
          >
            If you're working on something interesting — systems, AI tools, or
            anything that forces you to <Annotate type="underline"
              >learn by building</Annotate
            > — I'd like to hear about it.
          </h1>
        </div> -->

        <div class="grid gap-4">
          <h2
            class="max-w-[24ch] text-2xl font-semibold tracking-tight md:text-3xl"
          >
            The best way to reach me
          </h2>
          <p class="text-muted-foreground max-w-[56ch] text-base text-pretty">
            I'm always open to discussing new ideas, projects, or opportunities.
          </p>
        </div>

        <EmailLink />

        <div class="grid gap-2">
          <p class="text-muted-foreground text-sm">Based in Pune</p>
          <p class="text-muted-foreground max-w-[56ch] text-base text-pretty">
            Based in {siteConfig.location.city}, {siteConfig.location.country} ({
              siteConfig.location.timezoneLabel
            }). I'm open to internships, freelance projects, and collaboration
            on interesting systems or developer tools. Fluent in English.
          </p>
        </div>

        <div class="grid gap-6">
          {
            contactLinks.map((link, index) => (
              <div class="grid gap-4">
                <div class="grid gap-1">
                  <p class="text-lg font-semibold">{link.label}</p>
                  <p class="text-muted-foreground text-base">{link.copy}</p>
                </div>
                <a
                  href={link.href}
                  class="text-sm font-medium"
                  data-contact-label={link.label}
                >
                  Open profile
                </a>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>

<script is:inline>
  document.querySelectorAll("[data-contact-label]").forEach((link) => {
    link.addEventListener("click", () => {
      window.posthog?.capture("contact_link_clicked", {
        platform: link.dataset.contactLabel,
        href: link.getAttribute("href"),
      });
    });
  });
</script>
