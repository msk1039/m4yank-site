---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import FullSign from "../components/FullSign.astro";
import Annotate from "../components/Annotate.astro";
import IframeDialog from "../components/IframeDialog.astro";
import EmailLink from "../components/EmailLink.astro";
import SocialLinks from "../components/SocialLinks.astro";
import PatternBackground from "../components/PatternBackground.astro";
import ContestStats from "../components/ContestStats.astro";
import { siteLinks, hostname } from "../data/portfolio";
import { projects } from "../data/projects";

import {
  buildPersonSchema,
  buildProfilePageSchema,
  buildWebsiteSchema,
  siteConfig,
} from "../lib/seo";
import wavingHand from "../assets/emojis/waving-hand.webp";
import avatar from "../assets/icons/icon.png";

// Homepage uses the ProfilePage + Person + WebSite trio — Google's
// recommended combo for personal sites, which drives the Knowledge Panel
// and gives AI assistants a clear "this is a person" entity to cite.
const jsonLd = [
  buildProfilePageSchema(Astro.site),
  buildPersonSchema(Astro.site),
  buildWebsiteSchema(Astro.site),
];
---

<Layout
  title={siteConfig.name}
  description={siteConfig.description}
  jsonLd={jsonLd}
>
  <main class="isolate">
    <section class="bg-background section-shell">
      <!-- <PatternBackground name="dots" class="section-inner" size="48px"> -->
      <div class="grid gap-16">
        <div class="grid gap-12">
          <div class="grid gap-4">
            <div class="grid gap-6">
              <p class="text-muted-foreground text-sm">
                {siteConfig.location.city}, {siteConfig.location.country}. CS
                undergrad.
              </p>
              <h1
                class="max-w-[22ch] text-4xl leading-[1.25] font-semibold tracking-tight text-balance select-none md:text-6xl md:leading-[1.2]"
              >
                <!-- <span class="text-muted-foreground">Hi,</span> -->
                <!-- <Image
                  src={wavingHand}
                  alt="Waving hand"
                  width="96"
                  height="96"
                  quality={60}
                  class="inline-block size-[0.85em] translate-y-[-0.05em] align-middle"
                />
                <span class="text-muted-foreground">I'm</span> -->
                <!-- <Image
                  src={avatar}
                  alt="Mayank"
                  width="64"
                  height="64"
                  quality={70}
                  class="ring-border/70 inline-block size-[0.9em] translate-y-[-0.05em] rounded-full object-cover align-middle ring-1 dark:ring-white/10"
                /> -->
                <span class="text-foreground">Mayank Kadam</span>
                <!-- <span class="text-muted-foreground">I'm a</span>
                <span class="text-foreground">CS Undergrad</span>
                <span class="text-muted-foreground">at</span>
                <span class="text-foreground">PCCOE.</span> -->
              </h1>
              <SocialLinks
                size="size-5"
                class="-mt-2"
                eventName="hero_social_clicked"
              />
              <p
                class="text-muted-foreground max-w-[52ch] text-base text-pretty md:text-lg"
              >
                I like building things before I fully understand them, then
                pulling them apart until the theory starts to make sense. Most
                of my work lives at the intersection of systems, networking, and
                AI-powered developer tools.
              </p>
              <p
                class="text-muted-foreground max-w-[52ch] text-base text-pretty md:text-lg"
              >
                If you're building something interesting, thinking through
                systems, or just want to talk tech, feel free to reach out.
              </p>
              <!-- <EmailLink
                class="mt-2"
                emailClass="text-2xl sm:text-3xl md:text-4xl"
              /> -->
            </div>
          </div>

          <div class="grid gap-3">
            <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
              <IframeDialog
                id="resume"
                label={siteLinks.resume.label}
                title="Mayank's Resume"
                src={siteLinks.resume.pdf}
              />
              <a href="/blog">Read the blog</a>
            </div>
          </div>

          <div class="grid gap-10">
            <PatternBackground name="dots" size="48px" class="">
              <div
                class="bg-background mb-2 ml-2 flex w-full items-baseline justify-between gap-4 border border-dotted p-2"
              >
                <p class="text-muted-foreground text-sm">Selected work</p>
                <a
                  href="/projects"
                  class="group inline-flex items-center gap-1 text-sm font-medium no-underline"
                >
                  View all
                  <Icon
                    name="ri:arrow-right-line"
                    class="size-4 transition-transform group-hover:translate-x-0.5"
                  />
                </a>
              </div>
            </PatternBackground>

            <ul role="list" class="divide-border/40 grid gap-4 divide-y">
              {
                projects.map((project, index) => (
                  <PatternBackground
                    name="dots"
                    size="48px"
                    class="group"
                    patternClass="opacity-0 transition-opacity duration-200 ease-in-out group-hover:opacity-100 "
                  >
                    <li class="bg-background group-hover:outline-border mb-2 ml-2 outline outline-1 -outline-offset-1 outline-transparent transition-colors duration-200 ease-in-out outline-dotted first:pt-0 last:pb-0">
                      <a
                        href={project.href}
                        target="_blank"
                        rel="noreferrer"
                        class="grid gap-2 no-underline transition-transform duration-300 ease-in-out group-hover:translate-x-2 group-hover:-translate-y-3"
                        data-project-name={project.name}
                        data-project-href={project.href}
                      >
                        <h2 class="text-foreground text-xl font-medium tracking-tight sm:text-2xl">
                          {project.name}
                        </h2>
                        <p class="text-muted-foreground max-w-[56ch] text-sm text-pretty sm:text-base">
                          {project.description}
                        </p>
                        <span class="text-muted-foreground group-hover:text-foreground mt-1 inline-flex items-center gap-1 font-mono text-xs transition-colors">
                          {hostname(project.href)}
                          <Icon
                            name="ri:arrow-right-up-line"
                            class="size-3.5"
                          />
                        </span>
                      </a>
                    </li>
                  </PatternBackground>
                ))
              }
            </ul>
          </div>
          <div class="grid">
            <PatternBackground name="dots" size="48px" class="">
              <div
                class="bg-background mb-2 ml-2 flex w-full items-baseline justify-between gap-4 border border-dotted p-2"
              >
                <p class="text-muted-foreground text-sm">
                  Competitive programming
                </p>
                <!-- <a
                    href="/projects"
                    class="group inline-flex items-center gap-1 text-sm font-medium no-underline"
                  >
                    View all
                    <Icon
                      name="ri:arrow-right-line"
                      class="size-4 transition-transform group-hover:translate-x-0.5"
                    />
                  </a> -->
              </div>
            </PatternBackground>
            <ContestStats />
          </div>
        </div>
      </div>

      <!-- <div class="grid gap-4">
          <div class="grid gap-8">
            <div class="grid gap-4">
              <p class="text-muted-foreground text-sm">Where I'm headed</p>
              <h2
                class="max-w-[24ch] font-serif text-3xl font-normal tracking-tight text-balance italic md:text-4xl"
              >
                Toward systems and AI tooling, where <Annotate type="underline"
                  >theory and implementation</Annotate
                > reinforce each other.
              </h2>
              <p
                class="text-muted-foreground max-w-[56ch] text-base text-pretty"
              >
                I'm drawn to problems that force me to understand things from
                first principles — whether that's WebRTC networking, concurrent
                Go services, or AI agents that help developers write faster. I
                learn by building, break things to understand them, and keep
                shipping projects that stretch my comfort zone.
              </p>
              <FullSign class="h-12 w-auto sm:h-14" />
            </div>

            <div class="grid gap-4 text-sm">
              <p class="text-muted-foreground">Quick navigation</p>
              <div class="flex flex-wrap gap-x-6 gap-y-2" id="quick-nav">
                <a href="/work" class="font-medium" data-nav-label="work"
                  >View my work experience</a
                >

                <a href="/blog" data-nav-label="blog">Read my blog</a>
                <a href="/contact" data-nav-label="contact">Get in touch</a>
              </div>
            </div>
          </div>
        </div> -->
      <!-- </PatternBackground> -->
    </section>
  </main>

  <script is:inline>
    document.querySelectorAll("[data-project-name]").forEach((link) => {
      link.addEventListener("click", () => {
        window.posthog?.capture("project_clicked", {
          project_name: link.dataset.projectName,
          project_href: link.dataset.projectHref,
        });
      });
    });

    document.querySelectorAll("#quick-nav [data-nav-label]").forEach((link) => {
      link.addEventListener("click", () => {
        window.posthog?.capture("quick_nav_link_clicked", {
          destination: link.dataset.navLabel,
        });
      });
    });
  </script>
</Layout>
