---
import { marked } from "marked";
import { Icon } from "astro-icon/components";
import Layout from "../../layouts/Layout.astro";
import CodeCopy from "../../components/CodeCopy.astro";
import Carousel from "../../components/Carousel.astro";
import { projects, type Project } from "../../data/projects";
import { hostname } from "../../data/portfolio";
import { absoluteUrl, buildPersonRef } from "../../lib/seo";
import PatternBackground from "../../components/PatternBackground.astro";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;

const pageUrl = absoluteUrl(`/projects/${project.slug}`, Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  name: project.name,
  description: project.description,
  url: project.href,
  codeRepository: project.github,
  programmingLanguage: project.tags,
  author: buildPersonRef(Astro.site),
};

function githubReadmeUrl(
  githubUrl: string,
  branch: string = "main",
): string | null {
  const match = githubUrl.match(/github\.com\/([^/]+)\/([^/]+)/);
  if (!match) return null;
  const [, owner, repo] = match;
  return `https://raw.githubusercontent.com/${owner}/${repo}/${branch}/README.md`;
}

function readmeBases(
  readmeUrl: string,
  githubUrl?: string,
): { imageBase: string; linkBase: string } {
  if (readmeUrl.startsWith("http")) {
    const base = new URL("./", readmeUrl).href;
    const rawMatch = readmeUrl.match(
      /raw\.githubusercontent\.com\/([^/]+)\/([^/]+)\/([^/]+)\/README\.md/i,
    );
    if (rawMatch && githubUrl) {
      const [, owner, repo, branch] = rawMatch;
      return {
        imageBase: `https://raw.githubusercontent.com/${owner}/${repo}/${branch}/`,
        linkBase: `https://github.com/${owner}/${repo}/blob/${branch}/`,
      };
    }
    return { imageBase: base, linkBase: base };
  }
  return { imageBase: "/", linkBase: "/" };
}

function isRelativeUrl(url: string): boolean {
  return (
    !url.startsWith("http") && !url.startsWith("//") && !url.startsWith("#")
  );
}

function resolveUrl(url: string, base: string): string {
  if (!isRelativeUrl(url)) return url;
  return new URL(url, base).href;
}

async function fetchMarkdown(url: string): Promise<string | null> {
  const response = await fetch(url);
  if (!response.ok) return null;
  return response.text();
}

async function renderReadme(project: Project): Promise<string> {
  if (project.readme) {
    if (project.readme.startsWith("http")) {
      const markdown = await fetchMarkdown(project.readme);
      if (markdown !== null) {
        return await parseReadme(markdown, project.readme, project.github);
      }
    } else {
      try {
        const fs = await import("node:fs");
        const markdown = fs.readFileSync(project.readme, "utf-8");
        return await parseReadme(markdown, project.readme, project.github);
      } catch (error) {
        console.warn(`Failed to load README for ${project.slug}:`, error);
      }
    }
    return "";
  }

  if (!project.github) return "";

  const mainUrl = githubReadmeUrl(project.github, "main");
  if (!mainUrl) return "";

  let markdown = await fetchMarkdown(mainUrl);
  let resolvedReadmeUrl = mainUrl;

  if (markdown === null) {
    const masterUrl = githubReadmeUrl(project.github, "master");
    if (masterUrl) {
      markdown = await fetchMarkdown(masterUrl);
      resolvedReadmeUrl = masterUrl;
    }
  }

  if (markdown === null) {
    console.warn(`Failed to fetch README for ${project.slug}`);
    return "";
  }

  return await parseReadme(markdown, resolvedReadmeUrl, project.github);
}

async function parseReadme(
  markdown: string,
  readmeUrl: string,
  githubUrl?: string,
): Promise<string> {
  if (!markdown.trim()) return "";

  const { imageBase, linkBase } = readmeBases(readmeUrl, githubUrl);

  const renderer = new marked.Renderer();
  renderer.link = ({ href, title, text }) => {
    const url = resolveUrl(href, linkBase);
    return `<a href="${url}" title="${title || ""}">${text}</a>`;
  };
  renderer.image = ({ href, title, text }) => {
    const src = resolveUrl(href, imageBase);
    return `<img src="${src}" alt="${text}" title="${title || ""}" loading="lazy" decoding="async" />`;
  };

  return await marked.parse(markdown, {
    gfm: true,
    renderer,
  });
}

const readmeHtml = await renderReadme(project);

const projectSlides = project.images.map((src, index) => ({
  src,
  alt: `${project.name} screenshot ${index + 1}`,
}));
---

<Layout
  title={project.name}
  description={project.description}
  canonical={pageUrl}
  image={project.headerImage}
  jsonLd={jsonLd}
>
  <main class="isolate">
    <section class="section-shell">
      <div class="section-inner grid min-w-0 gap-12">
        <article class="grid min-w-0 gap-8">
          <Carousel
            slides={projectSlides}
            single
            controlsOutside
            slideHeight="aspect-[4/3] h-auto w-full"
            class="border-border/60 bg-muted overflow-hidden rounded-2xl border ring-1 ring-white/5 ring-inset"
          />

          <header class="grid gap-2">
            <p
              class="text-muted-foreground font-mono text-sm tracking-wide uppercase"
            >
              {project.status} · {project.tags[0]}
            </p>
            <h1
              class="max-w-[24ch] font-serif text-3xl font-semibold tracking-tight text-pretty italic md:text-5xl"
            >
              {project.name}
            </h1>
            <p class="text-muted-foreground max-w-[56ch] text-base text-pretty">
              {project.description}
            </p>
            <ul role="list" class="grid gap-2 pt-2">
              {
                project.highlights.map((highlight) => (
                  <li class="bg-background text-muted-foreground group-hover:outline-border mb-2 ml-2 border-l pl-2">
                    <span>{highlight}</span>
                  </li>
                ))
              }
            </ul>
          </header>

          <div class="flex flex-wrap items-center gap-4">
            {
              hostname(project.href) != "github.com" && (
                <a
                  href={project.href}
                  target="_blank"
                  rel="noreferrer"
                  class="group inline-flex items-center gap-1.5 font-mono text-sm no-underline"
                >
                  {hostname(project.href)}
                  <Icon
                    name="ri:arrow-right-up-line"
                    class="size-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                  />
                </a>
              )
            }

            {
              project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noreferrer"
                  class="group inline-flex items-center gap-1.5 font-mono text-sm no-underline"
                >
                  <Icon name="ri:github-line" class="size-4" />
                  {hostname(project.github)}
                  <Icon
                    name="ri:arrow-right-up-line"
                    class="size-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                  />
                </a>
              )
            }
          </div>

          <div class="flex flex-wrap gap-2">
            {
              project.tags.map((tag) => (
                <span class="bg-muted text-muted-foreground rounded px-2.5 py-1 font-mono text-xs tracking-wider uppercase">
                  {tag}
                </span>
              ))
            }
          </div>
          <PatternBackground name="dots" size="48px" class="">
            <div
              class="bg-background mb-2 ml-2 flex w-full items-baseline justify-between gap-4 border border-dotted p-2"
            >
              <p class="text-muted-foreground text-sm">Readme</p>
            </div>
          </PatternBackground>
          {
            readmeHtml && (
              <div class="prose max-w-none overflow-x-hidden">
                <div set:html={readmeHtml} />
              </div>
            )
          }
        </article>
      </div>
    </section>
  </main>
  <CodeCopy />
</Layout>
